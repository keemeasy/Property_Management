<odoo>

    <!-- PROPERTY FORM VIEW -->
    <record id="view_property_form" model="ir.ui.view">
        <field name="name">property.property.form</field>
        <field name="model">property.property</field>

        <field name="arch" type="xml">

            <form>

                <div class="oe_title">
                    <h1>
                        <field name="name" placeholder="Gebäude"/>
                    </h1>
                </div>

                <group col="4">

                    <field name="owner_id" string="Eigentümer"/>

                    <field name="street" string="Straße"/>

                    <field name="city" string="Stadt"/>

                    <field name="zip" string="PLZ"/>

                    <field name="country" string="Land"/>

                </group>


                <notebook>

                    <page string="Einheiten">


                        <!-- ================================= -->
                        <!-- BULK UNIT CREATION TOOL           -->
                        <!-- allows fast creation of units     -->
                        <!-- ================================= -->

                        <group string="Einheiten schnell erstellen" col="4">

                            <group>

                                <!-- how many units to create -->
                                <field name="bulk_unit_count"/>

                                <!-- starting number -->
                                <field name="bulk_start_number"/>

                                <!-- create empty rows -->
                                <button
                                    name="action_generate_empty_units"
                                    string="Leere Einheiten erstellen"
                                    type="object"
                                    class="btn-secondary"/>

                            </group>


                            <group>

                                <!-- optional default values -->

                                <field name="bulk_default_size"/>

                                <field name="bulk_default_rooms"/>

                                <field name="bulk_default_bathrooms"/>

                                <field name="bulk_default_floor"/>

                            </group>


                            <group>

                                <field name="bulk_default_balcony"/>

                                <field name="bulk_default_cellar"/>

                                <!-- create units already filled -->
                                <button
                                    name="action_generate_prefilled_units"
                                    string="Einheiten mit Werten erstellen"
                                    type="object"
                                    class="btn-primary"/>

                            </group>

                        </group>



                        <!-- EXISTING TABLE (unchanged) -->

                        <field name="unit_ids">

                            <tree editable="bottom">

                                <field name="name" string="Einheit"/>

                                <field name="size" string="m²"/>

                                <field name="active_tenant_ids"
                                       widget="many2many_tags"
                                       string="Mieter"
                                       readonly="1"/>

                                <field name="occupancy_status"
                                       string="Status"
                                       readonly="1"/>

                                <field name="current_rent"
                                       string="Warmmiete"
                                       readonly="1"/>

                            </tree>

                        </field>

                    </page>

                </notebook>

            </form>

        </field>
    </record>



    <!-- PROPERTY LIST VIEW -->
    <record id="view_property_tree" model="ir.ui.view">

        <field name="name">property.property.tree</field>

        <field name="model">property.property</field>

        <field name="arch" type="xml">

            <tree>

                <field name="name" string="Gebäude"/>

                <field name="city" string="Stadt"/>

                <field name="owner_id" string="Eigentümer"/>

                <field name="unit_count" string="Einheiten"/>

                <field name="rented_count" string="Vermietet"/>

                <field name="vacant_count" string="Leerstand"/>

            </tree>

        </field>

    </record>



    <!-- ACTION -->
    <record id="action_properties" model="ir.actions.act_window">

        <field name="name">Gebäude</field>

        <field name="res_model">property.property</field>

        <field name="view_mode">tree,form</field>

    </record>



    <!-- ROOT MENU -->
    <menuitem
        id="menu_property_root"
        name="Hausverwaltung"
        sequence="10"/>



    <!-- SUB MENU -->
    <menuitem
        id="menu_properties"
        name="Gebäude"
        parent="menu_property_root"
        action="action_properties"
        sequence="1"/>

</odoo>
