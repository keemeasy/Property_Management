<odoo>

    <!-- PROPERTY FORM VIEW -->
    <record id="view_property_form" model="ir.ui.view">
        <field name="name">property.property.form</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">

            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="owner_id"/>
                    </group>

                    <group>
                        <field name="street"/>
                        <field name="city"/>
                        <field name="zip"/>
                        <field name="country"/>
                    </group>


                    <!-- APARTMENTS TAB -->
                    <notebook>

                        <page string="Apartments">

                            <field name="unit_ids">

                                <tree editable="bottom">

                                    <field name="name"/>
                                    <field name="tenant_id"/>
                                    <field name="rent"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>


                </sheet>
            </form>

        </field>
    </record>


    <!-- PROPERTY LIST VIEW -->
    <record id="view_property_tree" model="ir.ui.view">
        <field name="name">property.property.tree</field>
        <field name="model">property.property</field>
        <field name="arch" type="xml">

            <tree>
                <field name="name"/>
                <field name="city"/>
                <field name="owner_id"/>
            </tree>

        </field>
    </record>


    <!-- ACTION -->
    <record id="action_properties" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">property.property</field>
        <field name="view_mode">tree,form</field>
    </record>


    <!-- ROOT MENU -->
    <menuitem id="menu_property_root"
              name="Property Management"
              sequence="10"/>


    <!-- SUB MENU -->
    <menuitem id="menu_properties"
              name="Properties"
              parent="menu_property_root"
              action="action_properties"
              sequence="1"/>

</odoo>
