<odoo>

    <!-- UNIT LIST VIEW -->
    <record id="view_unit_tree" model="ir.ui.view">

        <field name="name">property.unit.tree</field>

        <field name="model">property.unit</field>

        <field name="arch" type="xml">

            <tree>

                <field name="name" string="Einheit"/>

                <field name="number" string="Nr"/>

                <field name="property_id" string="Gebäude"/>

                <field name="size" string="m²"/>

                <field name="rooms" string="Zimmer"/>

                <field name="active_tenant_ids"
                       widget="many2many_tags"
                       string="Mieter"/>

                <field name="occupancy_status"
                       string="Status"/>

                <field name="current_rent"
                       string="Warmmiete"/>

            </tree>

        </field>

    </record>



    <!-- UNIT FORM VIEW -->
    <record id="view_unit_form" model="ir.ui.view">

        <field name="name">property.unit.form</field>

        <field name="model">property.unit</field>

        <field name="arch" type="xml">

            <form>

                <!-- GENERAL DATA -->
                <group string="Wohnung">

                    <field name="name"/>

                    <field name="number"/>

                    <field name="property_id"/>

                    <field name="size"/>

                    <field name="floor"/>

                    <field name="rooms"/>

                    <field name="bathrooms"/>

                </group>



                <!-- FEATURES -->
                <group string="Ausstattung">

                    <field name="has_cellar"/>

                    <field name="has_balcony"/>

                    <field name="parking"/>

                </group>



                <!-- RENT STATUS -->
                <group string="Mietstatus">

                    <field name="active_tenant_ids"
                           widget="many2many_tags"
                           readonly="1"/>

                    <field name="current_rent"
                           readonly="1"/>

                    <field name="occupancy_status"
                           readonly="1"/>

                </group>



                <!-- LEASE HISTORY -->
                <group string="Mietverträge">

                    <field name="lease_ids">

                        <tree>

                            <field name="tenant_ids"
                                   widget="many2many_tags"
                                   string="Mieter"/>

                            <field name="start_date"/>

                            <field name="end_date"/>

                            <field name="total_rent"/>

                            <field name="state"/>

                        </tree>

                    </field>

                </group>

            </form>

        </field>

    </record>



    <!-- ACTION -->
    <record id="action_units" model="ir.actions.act_window">

        <field name="name">Einheiten</field>

        <field name="res_model">property.unit</field>

        <field name="view_mode">tree,form</field>

    </record>



    <!-- MENU -->
    <menuitem
        id="menu_units"
        name="Einheiten"
        parent="menu_property_root"
        action="action_units"
        sequence="2"/>

</odoo>
